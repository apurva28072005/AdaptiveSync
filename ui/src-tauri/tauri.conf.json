{
  "$schema": "https://schema.tauri.app/config/2.11.2",
  "productName": "AdaptiveSync",
  "version": "1.0.0",
  "identifier": "com.adaptivesync.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "AdaptiveSync",
        "width": 960,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 720,
        "minHeight": 480
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}
